# Firebase Admin SDK — base64-encoded service account key (used by API routes)
# Generate: base64 -i path/to/service-account.json | tr -d '\n'
# Add this to Vercel env vars too (without NEXT_PUBLIC_ prefix — server-only)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Firebase project configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron job protection secret (generate any random string)
CRON_SECRET=

# Resend API key (resend.com — free tier)
RESEND_API_KEY=

# Email recipients for revision notifications
NOTIFICATION_EMAIL_1=
NOTIFICATION_EMAIL_2=
